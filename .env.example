# ============================================================
# Sahay Health Bot - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# These MUST also be set in Netlify Dashboard:
#   Site Settings > Environment Variables
# ============================================================

# ----- SUPABASE (PostgreSQL Database) -----
# Get these from: https://supabase.com/dashboard > Project Settings > API

# Project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=

# Public anonymous key - used by admin.html frontend via getSupabaseConfig function
SUPABASE_ANON_KEY=

# Service role key - used by backend functions (bypasses Row Level Security)
# NEVER expose this in frontend code
SUPABASE_SERVICE_ROLE_KEY=

# ----- MISTRAL AI (Conversation Engine) -----
# Get from: https://console.mistral.ai/api-keys
# Used by: getAiResponse function (model: mistral-small-latest)

MISTRAL_API_KEY=

# ----- ELEVENLABS (Text-to-Speech) -----
# Get from: https://elevenlabs.io/app/settings/api-keys
# Used by: textToSpeech function

ELEVENLABS_API_KEY=
