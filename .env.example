# ============================================================
# Sahay Health Bot - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# These MUST also be set in Netlify Dashboard:
#   Site Settings > Environment Variables
# ============================================================

# ----- SUPABASE (PostgreSQL Database) -----
# Get these from: https://supabase.com/dashboard > Project Settings > API

# Project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=

# Public anonymous key - used by admin.html frontend via getSupabaseConfig function
SUPABASE_ANON_KEY=

# Service role key - used by backend functions (bypasses Row Level Security)
# NEVER expose this in frontend code
SUPABASE_SERVICE_ROLE_KEY=

# ----- MISTRAL AI (Conversation Engine) -----
# Get from: https://console.mistral.ai/api-keys
# Used by: getAiResponse function (model: mistral-small-latest)

MISTRAL_API_KEY=

# ----- TEXT-TO-SPEECH -----
# Handled entirely client-side via Puter.js (https://puter.com)
# No API key or environment variable needed.

# ----- RESEND (Appointment Confirmation Email) -----
# Get from: https://resend.com/api-keys
# Free tier: 3000 emails/month, 100/day, no credit card required.
# Used by: bookAppointment function via lib/sendEmail.ts
# If unset, booking still works — email is best-effort and silently skipped.

RESEND_API_KEY=

# Sender address for confirmation emails. For new Resend accounts (no
# verified domain), leave this blank or set it to:
#   Medicall <onboarding@resend.dev>
# For production, verify a domain in Resend dashboard and set something like:
#   Medicall Health <noreply@yourdomain.com>

RESEND_FROM_EMAIL=
